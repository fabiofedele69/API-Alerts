
grep -Rni \
  --include='.gitlab-ci.yml' \
  --include='*.yml' \
  --include='*.yaml' \
  "DEPLOY_ENV_SUFFIX" \
  .gitlab-ci.yml \
  scmt-internal-api \
  scmt-rex-ansible \
  scmt-ubs-deploy-* \
