# ==========================================
# Database Backend
# ==========================================
DB_BACKEND=sqlite

# ==========================================
# SQLite Configuration
# ==========================================
SQLITE_DB_PATH=alerts.db

# ==========================================
# Oracle 19c Configuration
# ==========================================
ORACLE_USER=api_read_user
ORACLE_PASSWORD=change_me

ORACLE_HOST=your_oracle_host
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=your_service_name

ORACLE_SCHEMA=LC_SCMT

# Thin mode = false means use standard Thin mode (recommended first)
ORACLE_USE_THICK_MODE=false

# Only required if Thick mode is needed
ORACLE_CLIENT_LIB_DIR=
