python - <<'PY'
import oracledb

from app.config import settings
from app.vault import get_oracle_password

password = get_oracle_password()

dsn = oracledb.makedsn(
    settings.ORACLE_HOST,
    int(settings.ORACLE_PORT),
    service_name=settings.ORACLE_SERVICE,
)

connection = None
cursor = None

try:
    connection = oracledb.connect(
        user="LC_RCM_INC",
        password=password,
        dsn=dsn,
    )

    cursor = connection.cursor()

    cursor.execute("""
        SELECT
            SYS_CONTEXT('USERENV', 'SESSION_USER'),
            COUNT(*)
        FROM LC_SCMT.VW_API_REPORTER
        GROUP BY SYS_CONTEXT('USERENV', 'SESSION_USER')
    """)

    session_user, row_count = cursor.fetchone()

    print("Oracle connection successful")
    print("Session user:", session_user)
    print("VW_API_REPORTER row count:", row_count)

finally:
    if cursor is not None:
        cursor.close()

    if connection is not None:
        connection.close()
PY
