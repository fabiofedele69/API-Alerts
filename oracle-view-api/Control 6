from app.eva import read_eva_config
from app.vault import get_vault_token
import ssl
import json
import urllib.request

cfg = read_eva_config()
token = get_vault_token()

ctx = ssl.create_default_context(
    cafile="/app/M50/dyn/npa/certs/FA23303/cacerts.pem"
)
ctx.load_cert_chain(cfg["cert"], cfg["key"])

req = urllib.request.Request(
    cfg["secret_url"],
    headers={
        "X-Vault-Token": token,
        "X-Vault-Namespace": cfg["namespace"],
        "Accept": "application/json"
    }
)

with urllib.request.urlopen(req, context=ctx) as r:
    data = json.loads(r.read().decode())

print("Top-level keys:", list(data.keys()))

if "data" in data:
    print("Data keys:", list(data["data"].keys()))
    if isinstance(data["data"], dict) and "data" in data["data"]:
        print("Nested data keys:", list(data["data"]["data"].keys()))
