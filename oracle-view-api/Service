[Unit]
Description=FCSCMT API Reporter
After=network.target

[Service]
Type=simple

User=um501001
Group=um501001

WorkingDirectory=/export/home/um501001/api-reporter

Environment="LD_LIBRARY_PATH=/app/M50/m50-openssl-1.1.1w/lib"
Environment="PYTHONUNBUFFERED=1"

ExecStart=/export/home/um501001/api-reporter/venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8000

Restart=on-failure
RestartSec=5

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target


um501001 ALL=(root) NOPASSWD: /bin/systemctl start api-reporter.service, /bin/systemctl stop api-reporter.service, /bin/systemctl status api-reporter.service

Defaults:um501001 !requiretty

um501001 ALL=(root) NOPASSWD: \
/bin/systemctl start api-reporter, \
/bin/systemctl stop api-reporter, \
/bin/systemctl restart api-reporter, \
/bin/systemctl status api-reporter, \
/bin/systemctl reload api-reporter
