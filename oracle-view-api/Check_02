grep -Rni \
  --include='.gitlab-ci.yml' \
  '^\.publish-module:' \
  ci . \
  2>/dev/null | head -20

sed -n '140,200p' ci/.gitlab-ci.yml

bash -n scmt-reporter-api/deploy/src/bin/install-api-reporter.sh
bash -n scmt-reporter-api/deploy/src/bin/start-api-reporter.sh
git diff --check

for file in \
  scmt-reporter-api/app/requirements.txt \
  scmt-reporter-api/deploy/assembly.xml \
  scmt-reporter-api/deploy/src/bin/install-api-reporter.sh \
  scmt-reporter-api/deploy/src/bin/start-api-reporter.sh \
  scmt-reporter-api/deploy/src/services/api-reporter.service
do
  test -f "$file" && echo "OK: $file" || echo "MISSING: $file"
done


git status --short
git diff --stat



publish-m50-api-reporter-rpm:
  extends:
    - .m50-api-reporter-module
    - .publish-rpm-module
  variables:
    UBSCTL_FINGERPRINT_ARTIFACTS: ${ARTIFACT_PATTERN}
  rules:
    - if: '$CI_COMMIT_TAG =~ /^m50-api-reporter-v\d+(\.\d+)+$/'


if [[ ! -x "${APP_HOME}/venv/bin/python" ]]; then
    echo "Creating Python virtual environment..."
    rm -rf "${APP_HOME}/venv"
    "${PYTHON_BIN}" -m venv "${APP_HOME}/venv"

    echo "Installing Python dependencies..."
    "${APP_HOME}/venv/bin/python" -m pip install \
        --disable-pip-version-check \
        -r "${APP_HOME}/requirements.txt"
else
    echo "Existing Python virtual environment found."
    echo "Skipping dependency installation."
fi


/app/M50/m50-api-reporter/venv/bin/python -m pip show \
fastapi \
uvicorn \
oracledb \
python-dotenv \
openpyxl \
requests
